{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/apfs-rs/safety-gates.schema.json",
  "title": "APFS-RS Safety Gates",
  "type": "object",
  "required": ["schema_version", "status", "updated", "gates"],
  "properties": {
    "schema_version": {"type": "string"},
    "status": {"type": "string"},
    "updated": {"type": "string"},
    "purpose": {"type": "string"},
    "gates": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["description"],
        "properties": {
          "description": {"type": "string"},
          "required_for": {"type": "array", "items": {"type": "string"}},
          "required_reviews": {"type": "array", "items": {"type": "string"}},
          "required_tests": {"type": "array", "items": {"type": "string"}},
          "required_artifacts": {"type": "array", "items": {"type": "string"}},
          "required_checks": {"type": "array", "items": {"type": "string"}},
          "forbidden_targets": {"type": "array", "items": {"type": "string"}},
          "forbidden_until": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": true
      }
    },
    "path_policy": {"type": "object"}
  },
  "additionalProperties": true
}
