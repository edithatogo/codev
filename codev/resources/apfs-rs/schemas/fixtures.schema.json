{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/apfs-rs/fixtures.schema.json",
  "title": "APFS-RS Fixture Registry",
  "type": "object",
  "required": ["schema_version", "status", "updated", "fixture_policy", "fixtures"],
  "properties": {
    "schema_version": {"type": "string"},
    "status": {"type": "string"},
    "updated": {"type": "string"},
    "purpose": {"type": "string"},
    "fixture_policy": {"type": "object"},
    "manifest_schema": {"type": "object"},
    "fixtures": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["status", "milestone", "capability_ids", "source_type", "safe_to_commit"],
        "properties": {
          "status": {"type": "string"},
          "milestone": {"type": "string"},
          "capability_ids": {"type": "array", "items": {"type": "string"}},
          "source_type": {"type": "string"},
          "apfs_features": {"type": "object"},
          "generation_script": {"type": "string"},
          "mutation_script": {"type": "string"},
          "expected_result": {"type": "string"},
          "expected_artifacts": {"type": "array", "items": {"type": "string"}},
          "safe_to_commit": {"type": ["boolean", "string"]}
        },
        "additionalProperties": true
      }
    },
    "coverage_matrix": {"type": "object"}
  },
  "additionalProperties": true
}
