{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/apfs-rs/capabilities.schema.json",
  "title": "APFS-RS Capability Registry",
  "type": "object",
  "required": ["schema_version", "status", "updated", "milestones", "capabilities"],
  "properties": {
    "schema_version": {"type": "string"},
    "status": {"type": "string"},
    "updated": {"type": "string"},
    "purpose": {"type": "string"},
    "milestones": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["description", "default_write_policy"],
        "properties": {
          "description": {"type": "string"},
          "default_write_policy": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "capabilities": {
      "type": "object",
      "patternProperties": {
        "^[A-Z0-9]+(-[0-9A-Z]+)*$": {
          "type": "object",
          "required": ["name", "milestone", "moscow", "track", "crates", "required_tests", "safety_gates"],
          "properties": {
            "name": {"type": "string"},
            "milestone": {"type": "string"},
            "moscow": {"enum": ["Must", "Should", "Could", "Wont", "Won't", "Won't-yet"]},
            "track": {"type": "string"},
            "crates": {"type": "array", "items": {"type": "string"}},
            "required_tests": {"type": "array", "items": {"type": "string"}},
            "required_docs": {"type": "array", "items": {"type": "string"}},
            "safety_gates": {"type": "array", "items": {"type": "string"}},
            "forbidden_changes": {"type": "array", "items": {"type": "string"}},
            "dependencies_requiring_review": {"type": "array", "items": {"type": "string"}},
            "forbidden_until": {"type": "array", "items": {"type": "string"}}
          },
          "additionalProperties": true
        }
      }
    },
    "ci_contract": {"type": "object"}
  },
  "additionalProperties": true
}
